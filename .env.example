# Casa Radar — segredos (NUNCA meter no config.yaml nem commitar o .env real)
# Copia para .env e preenche. No GitHub, cria cada um como Secret
# (Settings -> Secrets and variables -> Actions -> New repository secret).

# --- Email (Gmail com App Password) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=o.teu.email@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
EMAIL_TO=para.onde.recebes@gmail.com

# --- WhatsApp (CallMeBot) ---
# Numero em formato internacional, ex: +351912345678
CALLMEBOT_PHONE=+3519XXXXXXXX
CALLMEBOT_APIKEY=123456

# --- Telegram (opcional, recomendado como canal mais fiavel) ---
TELEGRAM_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Um ou varios chat_id separados por virgula (ex: eu + a minha mulher):
TELEGRAM_CHAT_ID=111111111,222222222

# --- idealista via API (RapidAPI: idealista17) ---
# Subscreve a API "idealista17" na RapidAPI. So e usada se "idealista_api"
# estiver nas sources de uma pesquisa.
# Key por defeito (usada por qualquer URL sem key propria no config.yaml):
RAPIDAPI_KEY=
# Um token por concelho (ver idealista_urls no config.yaml). Cada um tem o seu
# limite gratis (100/mes), por isso cada concelho corre 3x/dia (~90/mes).
RAPIDAPI_KEY_1=
RAPIDAPI_KEY_2=
RAPIDAPI_KEY_3=
RAPIDAPI_KEY_4=
RAPIDAPI_KEY_5=
RAPIDAPI_KEY_6=

# --- Opcional ---
# LOG_LEVEL=INFO
